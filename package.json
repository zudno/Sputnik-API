{
    "name": "sputnik-api",
    "displayName": "Sputnik API",
    "description": "Cliente REST básico dentro del editor",
    "version": "0.0.2",
    "publisher": "zudno",
    "repository": {
        "type": "git",
        "url": "https://github.com/zudno/vscode-pets.git"
    },
    "engines": {
        "vscode": "^1.107.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "sputnik-api.open",
                "title": "New Request"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "sputnik-api-explorer",
                    "title": "Sputnik API",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "sputnik-api-explorer": [
                {
                    "type": "webview",
                    "id": "sputnik-api-view",
                    "name": "Sputnik API",
                    "icon": "media/icon.svg"
                }
            ]
        }

    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build:webview": "cd webview-ui && npm run build",
        "watch:webview": "cd webview-ui && npm run build -- --watch",
        "compile": "npm run build:webview && npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run build:webview && npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "24.x",
        "@types/vscode": "^1.107.0",
        "@vscode/test-cli": "^0.0.15",
        "@vscode/test-electron": "^3.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "npm-run-all": "^4.1.5",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1"
    },
    "overrides": {
        "diff": "^8.0.4",
        "serialize-javascript": "^7.0.6"
    },
    "license": "MIT",
    "dependencies": {
        "axios": "^1.18.1"
    }
}
